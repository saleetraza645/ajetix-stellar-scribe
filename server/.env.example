# MongoDB connection string (MongoDB Atlas recommended)
MONGO_URI=mongodb+srv://<user>:<pass>@cluster0.mongodb.net/ajetix?retryWrites=true&w=majority

# JWT signing secret — use a long random string
JWT_SECRET=change-me-to-a-64-char-random-string
JWT_EXPIRES_IN=7d

# Seed admin credentials (used by `bun run seed`)
ADMIN_EMAIL=admin@ajetix.com
ADMIN_PASSWORD=change-me-strong-password
ADMIN_NAME=Ajetix Admin

# Cloudinary (image uploads) — sign up free at cloudinary.com
CLOUDINARY_CLOUD_NAME=your-cloud
CLOUDINARY_API_KEY=your-key
CLOUDINARY_API_SECRET=your-secret

# Allowed origin for browser calls (comma-separated for multiple)
CORS_ORIGIN=https://ajetix.com,https://www.ajetix.com,http://localhost:8080

# Server port (Render/Railway auto-inject; leave default for local)
PORT=4000