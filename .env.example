# Frontend — copy to .env and fill in values

# Express API (required for admin panel + contact form)
VITE_API_BASE_URL=http://localhost:4000

# Public site URL (used in sitemap, canonical links, OG tags)
VITE_SITE_URL=https://ajetix.com

# Supabase (legacy — contact form no longer uses this)
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_PROJECT_ID=

# Optional: Google Search Console verification
# VITE_GOOGLE_SITE_VERIFICATION=
